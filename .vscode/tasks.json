{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build modbus sampler",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-pipe",
                "-fdiagnostics-color=always",
                "-static",
                "-std=c++20",
                "-O1",
                "-I${workspaceFolder}\\include",
                "-g",
                "${workspaceFolder}\\src\\modbus_csv_sampler_daemon.cpp",
                "${workspaceFolder}\\src\\workers\\ConsumerWorker.cpp",
                "${workspaceFolder}\\src\\workers\\CsvWorker.cpp",
                "${workspaceFolder}\\src\\workers\\ModbusWorker.cpp",
                "${workspaceFolder}\\include\\simomett\\common.cpp",
                "-o",
                "${workspaceFolder}\\dist\\modbus_csv_sampler_daemon.exe",
                "${workspaceFolder}\\libmodbus.dll"
            ],
            "options": {
                "cwd": "C:/msys64/ucrt64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build modbus plotter",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-pipe",
                "-fdiagnostics-color=always",
                "-std=c++20",
                "-O1",
                "-I${workspaceFolder}\\include",
                "-I${workspaceFolder}\\include\\imgui",
                "-I${workspaceFolder}\\include\\imgui\\backends",
                "-ISDL2",
                "-g",
                "${workspaceFolder}\\src\\modbus_graph_plotter.cpp",
                "${workspaceFolder}\\src\\workers\\ConsumerWorker.cpp",
                "${workspaceFolder}\\src\\workers\\GuiWorker.cpp",
                "${workspaceFolder}\\src\\workers\\ModbusWorker.cpp",
                "${workspaceFolder}\\src\\workers\\SamplesRingQueue.cpp",
                "${workspaceFolder}\\include\\imgui\\backends\\imgui_impl_sdl2.cpp",
                "${workspaceFolder}\\include\\imgui\\backends\\imgui_impl_opengl2.cpp",
                "${workspaceFolder}\\include\\imgui\\imgui.cpp",
                "${workspaceFolder}\\include\\imgui\\imgui_tables.cpp",
                "${workspaceFolder}\\include\\imgui\\imgui_widgets.cpp",
                "${workspaceFolder}\\include\\imgui\\imgui_draw.cpp",
                "${workspaceFolder}\\include\\imgui\\imgui_demo.cpp",
                "${workspaceFolder}\\include\\implot\\implot.cpp",
                "${workspaceFolder}\\include\\implot\\implot_items.cpp",
                "${workspaceFolder}\\include\\simomett\\common.cpp",
                "-o",
                "${workspaceFolder}\\dist\\modbus_graph_plotter.exe",
                "${workspaceFolder}\\libmodbus.dll",
                "-l:libwinpthread.a",
                "-lopengl32",
                "-lSDL2"
            ],
            "options": {
                "cwd": "C:/msys64/ucrt64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}